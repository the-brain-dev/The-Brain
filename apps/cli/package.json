{
  "name": "the-brain",
  "version": "0.1.0",
  "description": "Open memory platform for AI — 3-layer cognitive architecture, local-first, pluggable",
  "license": "MIT",
  "type": "module",
  "bin": {
    "the-brain": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "bun run --watch src/index.ts"
  },
  "dependencies": {
    "@the-brain/core": "workspace:*",
    "@the-brain/plugin-graph-memory": "workspace:*",
    "@the-brain/plugin-spm-curator": "workspace:*",
    "@the-brain/plugin-harvester-cursor": "workspace:*",
    "@the-brain/plugin-harvester-claude": "workspace:*",
    "@the-brain/plugin-identity-anchor": "workspace:*",
    "@the-brain/plugin-auto-wiki": "workspace:*",
    "@the-brain/trainer-local-mlx": "workspace:*",
    "@the-brain/mcp-server": "workspace:*",
    "cac": "^6.7.14",
    "consola": "^3.4.0"
  }
}

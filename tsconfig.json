{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@my-brain/core": ["./packages/core/src"],
      "@my-brain/core/*": ["./packages/core/src/*"],
      "@my-brain/plugin-graph-memory": ["./packages/plugin-graph-memory/src"],
      "@my-brain/plugin-spm-curator": ["./packages/plugin-spm-curator/src"],
      "@my-brain/plugin-harvester-cursor": ["./packages/plugin-harvester-cursor/src"],
      "@my-brain/plugin-identity-anchor": ["./packages/plugin-identity-anchor/src"],
      "@my-brain/plugin-auto-wiki": ["./packages/plugin-auto-wiki/src"]
    }
  },
  "include": ["packages/**/*.ts", "apps/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
